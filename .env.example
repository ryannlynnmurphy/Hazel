# HZL Security — Environment Variables Template
# ================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to GitHub. This file (.env.example) is safe to commit.
#
# cp .env.example .env
# then fill in each value.

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_ME

# ── ElevenLabs (Hazel TTS) ────────────────────────────────────────────────────
ELEVEN_LABS_API_KEY=REPLACE_ME
HAZEL_VOICE_ID=Uc7anshoV8mdBhDnEZEX

# ── Tavily Search ─────────────────────────────────────────────────────────────
TAVILY_API_KEY=REPLACE_ME

# ── Hazel WebSocket Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
HZL_WS_SECRET=REPLACE_ME_generate_with_command_above
HZL_WS_TOKEN_EXPIRY=3600

# ── HZL Academy (Next.js) ─────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
HZL_JWT_SECRET=REPLACE_ME_generate_with_command_above
NEXT_PUBLIC_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Google OAuth2 (Gmail / Calendar for Hazel) ────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2/callback

# ── Home Assistant (Hazel) ────────────────────────────────────────────────────
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=REPLACE_ME

# ── Database ──────────────────────────────────────────────────────────────────
HAZEL_DB_PATH=~/jarvis/hazel.db
HZL_ACADEMY_DB_PATH=./data/hzl_academy.db

# ── Rate Limiting ─────────────────────────────────────────────────────────────
HZL_MAX_INPUT_LENGTH=4000
HZL_WS_RATE_LIMIT_MESSAGES=10
HZL_WS_RATE_LIMIT_WINDOW=10

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
PYTHON_ENV=development
